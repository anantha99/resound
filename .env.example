# OpenRouter — required. One key, ~300 models.
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Apify public-listening actors. Apify's synchronous start request waits at
# most 60 seconds; longer runs are polled until completion. The poll timeout
# must remain below the 15-minute public-listening activity timeout.
APIFY_API_TOKEN=
APIFY_RUN_POLL_TIMEOUT_SECONDS=600
APIFY_RUN_POLL_INTERVAL_SECONDS=2

# Database — defaults to local SQLite. Production should use a Postgres URL and
# run Alembic migrations before starting API/worker processes.
# Example: postgresql+psycopg://user:pass@host:5432/resound
RESOUND_DATABASE_URL=sqlite:///./data/resound.db

# Tenant context — local/demo mode allows requests without tenant headers. Set
# true in production so tenant-owned APIs require X-Resound-Organization.
RESOUND_REQUIRE_TENANT_HEADER=false

# Reddit backend selector — "composio" (default; uses Composio's managed
# OAuth app, no Reddit Responsible Builder approval needed) or "praw"
# (direct Reddit API; requires REDDIT_CLIENT_ID/SECRET below).
REDDIT_BACKEND=composio

# Composio — required when REDDIT_BACKEND=composio. Get from https://app.composio.dev
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=

# Composio toolkit version pin — required for manual tools.execute calls.
# Look up the latest at platform.composio.dev or via the SDK:
#   composio.toolkits.get(slug='reddit').meta.available_versions
COMPOSIO_TOOLKIT_VERSION_REDDIT=

# Reddit API (PRAW) — required when REDDIT_BACKEND=praw.
# Get from https://www.reddit.com/prefs/apps (note: Reddit's Responsible Builder
# Policy gates new credentials as of Nov 2025).
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=resound:v0.1.0 (by /u/your_reddit_username)

# Twitter / X API — get from https://developer.twitter.com
TWITTER_BEARER_TOKEN=

# Model selection lives in config/models.yaml (with optional per-brand
# overrides in brands/<slug>/models.yaml). See docs/design_decisions.md
# for the merge semantics.

# Optional — OpenRouter app attribution (shows in their dashboard)
OPENROUTER_APP_URL=https://github.com/resound
OPENROUTER_APP_NAME=Resound

# Logging
RESOUND_LOG_LEVEL=INFO

# API / web client
# Comma-separated list of allowed browser origins for the FastAPI backend.
# Example: RESOUND_CORS_ORIGINS=https://app.example.com,http://localhost:5000
RESOUND_CORS_ORIGINS=http://localhost:5000,http://localhost:5173
# Vite frontend only: set to the same organization used by the demo population
# command. Leave empty for local backends with tenant enforcement disabled.
VITE_RESOUND_ORGANIZATION=

# Temporal worker runtime. Local dev can use: temporal server start-dev
RESOUND_TEMPORAL_ADDRESS=127.0.0.1:7233
RESOUND_TEMPORAL_NAMESPACE=default
RESOUND_TEMPORAL_TASK_QUEUE=resound-default
RESOUND_WORKER_IDENTITY=
