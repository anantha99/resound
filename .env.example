# Anthropic API — required
ANTHROPIC_API_KEY=

# Database — defaults to local SQLite. For production set to a Postgres URL.
# Example: postgresql+psycopg://user:pass@host:5432/resound
RESOUND_DATABASE_URL=sqlite:///./data/resound.db

# Reddit API — get from https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=resound:v0.1.0 (by /u/your_reddit_username)

# Twitter / X API — get from https://developer.twitter.com
TWITTER_BEARER_TOKEN=

# Optional — model overrides
RESOUND_CLASSIFIER_MODEL=claude-sonnet-4-6
RESOUND_FILTER_MODEL=claude-haiku-4-5-20251001

# Logging
RESOUND_LOG_LEVEL=INFO
